{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "mutate": [
    "src/renderer.ts",
    "src/theme.ts",
    "src/parser.ts",
    "src/styles.ts"
  ],
  "testRunner": "command",
  "commandRunner": {
    "command": "bun test src/__tests__/renderer.test.ts src/__tests__/styles.test.ts src/__tests__/parser.test.ts src/__tests__/property-svg-wellformedness.test.ts"
  },
  "reporters": ["html", "clear-text", "progress"],
  "timeoutMS": 30000,
  "concurrency": 4
}
