{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "_comment": "Narrow mutation lane for pie parsing, layout, rendering, and structured mutation.",
  "mutate": ["src/agent/pie-body.ts", "src/pie/parser.ts", "src/pie/layout.ts"],
  "ignorePatterns": ["/site/**", "/dist/**", "/coverage/**", "/.stryker-tmp-*/**"],
  "testRunner": "command",
  "commandRunner": {
    "command": "bun test src/__tests__/agent-pie.test.ts src/__tests__/pie.test.ts src/__tests__/agent-mermaid-corpus.test.ts"
  },
  "reporters": ["clear-text", "progress", "json"],
  "jsonReporter": { "fileName": "reports/mutation/pie-mutation.json" },
  "timeoutMS": 30000,
  "concurrency": 2,
  "tempDirName": ".stryker-tmp-pie",
  "disableTypeChecks": true
}
