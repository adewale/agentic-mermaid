{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.adewale/agentic-mermaid",
  "title": "Agentic Mermaid",
  "description": "Render, verify, describe, and safely edit Mermaid diagrams through MCP.",
  "repository": {
    "url": "https://github.com/adewale/agentic-mermaid",
    "source": "github"
  },
  "version": "0.2.0",
  "websiteUrl": "https://agentic-mermaid.dev/",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "agentic-mermaid",
      "version": "0.2.0",
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        }
      ],
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://agentic-mermaid.dev/mcp"
    }
  ]
}
