{
  "name": "agentic-mermaid",
  "mcpName": "io.github.adewale/agentic-mermaid",
  "version": "0.1.1",
  "license": "MIT",
  "description": "Agentic Mermaid: render, verify, and safely edit Mermaid diagrams as ASCII, PNG, SVG, or structured agent workflows — with composable styles (hand-drawn, excalidraw, watercolor, or your own as JSON).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js",
      "default": "./dist/agent.js"
    },
    "./style-spec.schema.json": "./docs/schemas/style-spec.schema.json",
    "./package.json": "./package.json"
  },
  "bin": {
    "am": "dist/am.js",
    "agentic-mermaid": "dist/am.js",
    "agentic-mermaid-mcp": "dist/agentic-mermaid-mcp.js"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adewale/agentic-mermaid.git"
  },
  "homepage": "https://agentic-mermaid.dev/",
  "bugs": {
    "url": "https://github.com/adewale/agentic-mermaid/issues"
  },
  "keywords": [
    "mermaid",
    "agentic-mermaid",
    "agent",
    "ai",
    "mcp",
    "cli",
    "diagram",
    "svg",
    "png",
    "ascii",
    "flowchart",
    "sequence-diagram",
    "class-diagram",
    "er-diagram",
    "timeline-diagram",
    "journey-diagram",
    "architecture-diagram",
    "xychart",
    "pie-chart",
    "quadrant-chart",
    "gantt-chart",
    "state-diagram",
    "mindmap",
    "git-graph",
    "radar-chart",
    "visualization",
    "theming",
    "styles",
    "hand-drawn",
    "sketch",
    "excalidraw",
    "watercolor",
    "llms-txt"
  ],
  "author": "Adewale",
  "files": [
    "dist/",
    "assets/fonts/",
    "docs/schemas/style-spec.schema.json",
    "examples/styles/",
    "skills/",
    "server.json",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE",
    "LICENSES/",
    "THIRD_PARTY_NOTICES.md",
    "README.md",
    "!dist/**/*.map"
  ],
  "scripts": {
    "test": "bun test --coverage --timeout 30000 src/__tests__/",
    "typecheck": "bun run website/build.ts && tsc --noEmit",
    "test:browser": "bun run e2e/run-browser-contracts.ts",
    "editor": "bun run scripts/site/editor.ts",
    "dev": "bun run website:dev",
    "bench": "bun run eval/benchmark/sample-bench.ts",
    "benchmark:palette": "bun run eval/palette-performance/run.ts --record",
    "benchmark:palette:check": "bun run eval/palette-performance/run.ts --check",
    "harvest:upstream": "bun run eval/mermaid-upstream-suite-bench/harvest.ts",
    "harvest:upstream:refresh-check": "bun run eval/mermaid-upstream-suite-bench/refresh-check.ts",
    "build": "tsup",
    "build:binary": "bun build ./bin/am.ts --compile --outfile dist/am",
    "website": "bun run website/build.ts",
    "website:check": "bun run website/build.ts --check",
    "website:dev": "cd website && WRANGLER_SEND_METRICS=false npx --yes wrangler@latest dev --port 9095 --ip 127.0.0.1",
    "deploy": "bun run website && cd website && WRANGLER_SEND_METRICS=false npx --yes wrangler@latest deploy",
    "prepublishOnly": "npm run build",
    "goldens:ascii": "bun run scripts/update-ascii-goldens.ts",
    "goldens:ascii:check": "bun run scripts/update-ascii-goldens.ts --check",
    "hero": "bun run scripts/site/hero.ts",
    "hero:check": "bun run scripts/site/hero.ts --check",
    "site": "bun run website",
    "site:check": "bun run website:check",
    "style:audit": "bun test src/__tests__/style-role-audit.test.ts",
    "sketch:check": "bun test scripts/sketch-prototype/styles.test.ts && bun run scripts/sketch-prototype/contrast-audit.ts",
    "characterization:check": "bun run scripts/characterization/contact-sheet.ts --check && bun run scripts/characterization/contact-sheet-families.ts --check && bun run scripts/characterization/visual-quality.ts --check",
    "agent-doc-artifacts": "bun run scripts/generate-agent-doc-artifacts.ts",
    "agent-doc-artifacts:check": "bun run scripts/generate-agent-doc-artifacts.ts --check",
    "section-a-report": "bun run scripts/generate-section-a-capability-report.ts",
    "section-a-report:check": "bun run scripts/generate-section-a-capability-report.ts --check",
    "section-b-report": "bun run scripts/generate-section-b-capability-report.ts",
    "section-b-report:check": "bun run scripts/generate-section-b-capability-report.ts --check",
    "render-options-docs": "bun run scripts/generate-render-options-docs.ts",
    "render-options-docs:check": "bun run scripts/generate-render-options-docs.ts --check",
    "style-spec-artifacts": "bun run scripts/generate-style-spec-artifacts.ts",
    "style-spec-artifacts:check": "bun run scripts/generate-style-spec-artifacts.ts --check",
    "upstream-manifest": "bun run scripts/generate-upstream-mermaid-manifest.ts",
    "upstream-manifest:check": "bun run scripts/generate-upstream-mermaid-manifest.ts --check",
    "mutation-test": "bun run scripts/quality/mutation-profile.ts",
    "sabotage:routes": "bun run eval/sabotage/route-regressions.ts",
    "test:family-elevation-reverts": "bun run scripts/quality/family-elevation-revert-probes.ts",
    "lint": "bun test src/__tests__/agent-substrate-lint.test.ts src/__tests__/test-quality-lint.test.ts",
    "eval:agent-live": "bun run eval/agent-usage/live.ts",
    "eval:agent-subagent": "bun run eval/agent-usage/capture-subagent-prompt-eval.ts",
    "rubric:visual": "bun run eval/visual-rubric/run.ts",
    "contact:sheet": "bun run eval/visual-rubric/contact-sheet.ts",
    "contact:sheet:test-portfolio": "bun run scripts/pr-assets/test-portfolio-contact-sheet.ts",
    "contact:sheet:test-portfolio:review": "bun run scripts/ci/test-portfolio-visual-review.ts",
    "gallery:custom-styles": "bun run scripts/docs/custom-style-cookbook.ts",
    "gallery:custom-styles:check": "bun run scripts/docs/custom-style-cookbook.ts --check",
    "gallery:linkrank-feedback-packing": "bun run scripts/pr-assets/linkrank-feedback-packing-evidence.ts",
    "gallery:linkrank-feedback-packing:check": "bun run scripts/pr-assets/linkrank-feedback-packing-evidence.ts --check",
    "gallery:mindmap-gitgraph": "bun run scripts/pr-assets/mindmap-gitgraph-content-gallery.ts",
    "gallery:mindmap-gitgraph:check": "bun run scripts/pr-assets/mindmap-gitgraph-content-gallery.ts --check",
    "gallery:mermaid-docs": "bun run scripts/pr-assets/mermaid-doc-showcase-gallery.ts",
    "gallery:mermaid-docs:check": "bun run scripts/pr-assets/mermaid-doc-showcase-gallery.ts --check",
    "gallery:style-switch": "bun run scripts/pr-assets/style-switch-contact-sheet.ts",
    "gallery:style-switch:check": "bun run scripts/pr-assets/style-switch-contact-sheet.ts --check",
    "gallery:pie-highlight": "bun run scripts/pr-assets/pie-highlightslice-evidence.ts",
    "gallery:pie-highlight:check": "bun run scripts/pr-assets/pie-highlightslice-evidence.ts --check",
    "gallery:palette-rollout:baseline": "bun run scripts/pr-assets/palette-rollout-evidence.ts --record-baseline",
    "gallery:palette-rollout": "bun run scripts/pr-assets/palette-rollout-evidence.ts",
    "gallery:palette-rollout:check": "bun run scripts/pr-assets/palette-rollout-evidence.ts --check",
    "gallery:palette-harmony": "bun run scripts/pr-assets/palette-harmony-experiment.ts",
    "gallery:palette-harmony:check": "bun run scripts/pr-assets/palette-harmony-experiment.ts --check",
    "gallery:section-b": "bun run scripts/pr-assets/section-b-brand-evidence.ts",
    "gallery:section-b:check": "bun run scripts/pr-assets/section-b-brand-evidence.ts --check",
    "track": "bun run eval/heuristic-tracker/run.ts",
    "audit:ugly": "bun run eval/ugly-detector/audit.ts",
    "audit:dependencies": "bun audit --audit-level=high"
  },
  "dependencies": {
    "@resvg/resvg-js": "2.6.2",
    "acorn": "8.16.0",
    "elkjs": "^0.11.0",
    "entities": "^7.0.1",
    "perfect-freehand": "1.2.3",
    "roughjs": "4.6.6",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "lodash-es": "4.18.1",
    "picomatch": "4.0.5",
    "qs": "6.15.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@resvg/resvg-wasm": "2.6.2",
    "@stryker-mutator/core": "^9.6.1",
    "@types/bun": "^1.3.9",
    "beautiful-mermaid": "1.1.3",
    "fast-check": "^4.6.0",
    "mermaid": "11.16.0",
    "mermaid-ast": "0.8.2",
    "playwright": "^1.58.2",
    "shiki": "^3.19.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "upng-js": "^2.1.0"
  }
}
