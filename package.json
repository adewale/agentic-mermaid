{
  "name": "agentic-mermaid",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Agentic Mermaid: render, verify, and safely edit Mermaid diagrams as ASCII, PNG, SVG, or structured agent workflows.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./agent": {
      "bun": "./src/agent/index.ts",
      "import": "./dist/agent.js",
      "types": "./dist/agent.d.ts",
      "default": "./dist/agent.js"
    }
  },
  "bin": {
    "am": "./dist/am.js",
    "agentic-mermaid": "./dist/am.js",
    "agentic-mermaid-mcp": "./dist/agentic-mermaid-mcp.js"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adewale/beautiful-mermaid"
  },
  "homepage": "https://adewale.github.io/beautiful-mermaid/",
  "bugs": {
    "url": "https://github.com/adewale/beautiful-mermaid"
  },
  "keywords": [
    "mermaid",
    "agentic-mermaid",
    "agent",
    "ai",
    "mcp",
    "cli",
    "diagram",
    "svg",
    "png",
    "ascii",
    "flowchart",
    "sequence-diagram",
    "class-diagram",
    "er-diagram",
    "timeline-diagram",
    "journey-diagram",
    "architecture-diagram",
    "xychart",
    "pie-chart",
    "quadrant-chart",
    "gantt-chart",
    "state-diagram",
    "visualization",
    "theming"
  ],
  "author": "Adewale",
  "files": [
    "src/",
    "dist/",
    "bin/",
    "assets/fonts/",
    "assets/hero.png",
    "docs/",
    "skills/",
    "evals/",
    "examples/agent-loop.ts",
    "examples/mcp-vs-cli-complex-diagrams.ts",
    "examples/agent-improve-auth-flow.ts",
    "Instructions_for_agents.md",
    "AGENT_NATIVE.md",
    "CHANGELOG.md",
    "TODO.md",
    "SECURITY.md",
    "llms.txt",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "bun test --coverage src/__tests__/",
    "test:browser": "cd e2e && bun test . --timeout 600000",
    "samples": "bun run scripts/site/generate.ts",
    "editor": "bun run scripts/site/editor.ts",
    "dev": "bun run scripts/dev.ts",
    "bench": "bun run eval/benchmark/sample-bench.ts",
    "build": "tsup",
    "build:binary": "bun build ./bin/am.ts --compile --outfile dist/am",
    "build:site": "bun run scripts/site/generate.ts && bun run scripts/site/editor.ts && bun run scripts/site/differences.ts && mkdir -p site/editor site/differences && mv index.html site/index.html && cp editor.html site/editor.html && cp editor.html site/editor/index.html && rm editor.html && cp differences.html site/differences.html && cp differences.html site/differences/index.html && rm differences.html && cp -r public/* site/ && cp -r public/* site/editor/ && bun run bin/am.ts llms-txt > site/llms.txt && bun run bin/am.ts --agent-instructions > site/agent-instructions.md",
    "deploy": "echo 'GitHub Pages deploys from main via .github/workflows/pages.yml; Cloudflare deployment is upstream-owned.'",
    "xychart-test": "bun run scripts/site/xychart-test.ts",
    "prepublishOnly": "npm run build",
    "goldens:ascii": "bun run scripts/update-ascii-goldens.ts",
    "goldens:ascii:check": "bun run scripts/update-ascii-goldens.ts --check",
    "characterization:check": "bun run scripts/characterization/contact-sheet.ts --check && bun run scripts/characterization/contact-sheet-families.ts --check && bun run scripts/characterization/visual-quality.ts --check",
    "mutation-test": "npx stryker run",
    "mutation-test:characterization": "npx stryker run stryker.characterization.config.json",
    "mutation-test:ascii": "npx stryker run stryker.ascii.config.json",
    "mutation-test:families": "npx stryker run stryker.families.config.json",
    "mutation-test:routes": "npx stryker run stryker.routes.config.json",
    "mutation-test:routes:certs": "npx stryker run stryker.route-certificates.config.json",
    "mutation-test:routes:subgraph": "npx stryker run stryker.subgraph-routing.config.json",
    "mutation-test:links": "npx stryker run stryker.link-grammar.config.json",
    "sabotage:routes": "bun run eval/sabotage/route-regressions.ts",
    "mutation-test:gantt": "npx stryker run stryker.gantt.config.json",
    "lint": "bun test src/__tests__/agent-substrate-lint.test.ts",
    "eval:agent-live": "bun run eval/agent-usage/live.ts",
    "rubric:visual": "bun run eval/visual-rubric/run.ts",
    "contact:sheet": "bun run eval/visual-rubric/contact-sheet.ts",
    "track": "bun run eval/heuristic-tracker/run.ts",
    "audit:ugly": "bun run eval/ugly-detector/audit.ts"
  },
  "dependencies": {
    "@resvg/resvg-js": "2.6.2",
    "elkjs": "^0.11.0",
    "entities": "^7.0.1",
    "mermaid-ast": "0.8.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@types/bun": "^1.3.9",
    "fast-check": "^4.6.0",
    "playwright": "^1.58.2",
    "shiki": "^3.19.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
