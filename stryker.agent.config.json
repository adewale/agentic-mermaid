{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "mutate": [
    "src/agent/mutate.ts",
    "src/agent/serialize.ts"
  ],
  "testRunner": "command",
  "commandRunner": {
    "command": "bun test src/__tests__/agent.test.ts"
  },
  "reporters": ["clear-text"],
  "timeoutMS": 20000,
  "concurrency": 2,
  "tempDirName": ".stryker-tmp-agent",
  "disableTypeChecks": true
}
