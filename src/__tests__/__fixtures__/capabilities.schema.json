{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AmCapabilitiesEnvelope",
  "description": "Shape emitted by `am capabilities`. Loop 7 / A3.1.",
  "type": "object",
  "required": ["sdkVersion", "families", "warningCodes", "outputFormats", "sectionA"],
  "properties": {
    "sdkVersion": {
      "type": "string",
      "description": "package.json version of the running CLI."
    },
    "families": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "hasMutate", "hasExtractLabels", "mutationOps", "editPolicy"],
        "properties": {
          "id": { "type": "string" },
          "hasMutate": { "type": "boolean" },
          "hasExtractLabels": { "type": "boolean" },
          "mutationOps": {
            "type": "array",
            "items": { "type": "string" }
          },
          "editPolicy": {
            "type": "string",
            "enum": ["structured-when-narrowed", "source-level-only"]
          }
        }
      }
    },
    "warningCodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "tier", "severity"],
        "properties": {
          "code": { "type": "string" },
          "tier": { "type": "string", "enum": ["structural", "geometric", "lint"] },
          "severity": { "type": "string", "enum": ["error", "warning"] }
        }
      }
    },
    "outputFormats": {
      "type": "array",
      "items": { "type": "string", "enum": ["svg", "ascii", "unicode", "png", "json"] }
    },
    "sectionA": {
      "type": "object",
      "description": "Bounded discovery summary of the audit-only Section A report.",
      "required": ["projectionVersion", "reportSchemaVersion", "reportDigest", "upstreamPin", "counts", "noAbsentSyntaxCapabilities", "fullReport"]
    }
  }
}
