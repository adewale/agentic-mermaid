{
  "schemaVersion": 1,
  "target": "Mermaid 11.16.0",
  "researchedAt": "2026-07-12",
  "method": "Scenario selection starts with official Mermaid docs/specs and issue/PR examples, then weights ecosystem signals by a reproducible point-in-time sample of the most-starred forks. The exact API URLs, response hashes, ranking rule, sample sizes, exclusion of this evaluation target, and retained fork identities are in fork-snapshot.json. Forks without family-specific syntax changes influence terminal, install, and real-content stress priorities; they are not syntax authorities.",
  "forkSnapshot": "fork-snapshot.json",
  "forkGraphSnapshot": [
    {
      "root": "mermaid-js/mermaid",
      "sampledForks": [
        {
          "repo": "jacob-lcs/mermaid",
          "stars": 164
        },
        {
          "repo": "jgraph/mermaid",
          "stars": 50
        },
        {
          "repo": "Mermaid-Chart/mermaid-develop",
          "stars": 20
        }
      ],
      "sampleWeight": 234,
      "finding": "No sampled fork added a distinct Mindmap/GitGraph language. Official docs/issues remain the syntax authority; high-weight fork activity reinforces labels, layout, themes, and renderer robustness."
    },
    {
      "root": "lukilabs/beautiful-mermaid",
      "sampledForks": [
        {
          "repo": "vercel-labs/beautiful-mermaid",
          "stars": 28
        },
        {
          "repo": "ysknsid25/beautiful-mermaid",
          "stars": 4
        }
      ],
      "sampleWeight": 32,
      "finding": "Distribution and layout forks dominate; issue #85 supplies direct demand for attractive Mindmap support."
    },
    {
      "root": "AlexanderGrooff/mermaid-ascii",
      "sampledForks": [
        {
          "repo": "ColtWindy/mermaid-ascii",
          "stars": 1
        }
      ],
      "sampleWeight": 1,
      "finding": "Issue #74 reports 593 real RFC diagrams and motivates hard-width terminal projections even though Mindmap/GitGraph are not yet supported upstream."
    }
  ],
