{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "_comment": "Scoped mutation lane for the honorLinkRankDistance packing repair + reconnect fallbacks (issue #81 fix). A surviving mutant in the overlap gate or the push-ahead arithmetic would mean the shove can silently leave overlapping boxes again.",
  "mutate": [
    "src/layout/passes/index.ts:931-1165"
  ],
  "ignorePatterns": [
    "/site/**",
    "/dist/**",
    "/coverage/**",
    "/website/**",
    "/.stryker-tmp*/**",
    "/.claude/**",
    "/.agents/**"
  ],
  "testRunner": "command",
  "commandRunner": {
    "command": "bun test src/__tests__/linkrank-packing.test.ts src/__tests__/feedback-reroute.test.ts src/__tests__/layout-equivalence.test.ts"
  },
  "reporters": [
    "clear-text",
    "progress",
    "json"
  ],
  "jsonReporter": {
    "fileName": "reports/mutation/linkrank-mutation.json"
  },
  "timeoutMS": 90000,
  "concurrency": 4,
  "tempDirName": ".stryker-tmp-linkrank",
  "disableTypeChecks": true
}