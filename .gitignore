# Test coverage
coverage/

# Private eval prompts / answer keys
# Public manifests may reference these paths as hidden holdout/holdback stubs.
evals/private/

# Browser test screenshots (generated by agent-browser)
e2e/screenshots/current-*.png

# Stryker mutation testing
.stryker-tmp/
.stryker-tmp-*/
reports/
dist/am

# Claude Code agent worktrees + personal settings (session-transient, never ship).
# Exception: the shared SessionStart hook (.claude/settings.json) IS committed so
# fresh web/CI sessions run `bun install` before the suite (testing-tools #1).
.claude/*
!.claude/settings.json

# Vendored agent skills (installed locally via `npx skills add`, never shipped —
# the repo's distribution policy ships skills under skills/ instead)
.agents/
skills-lock.json
