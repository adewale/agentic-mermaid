# Dependencies
node_modules/

# Build output
dist/
/site/
*.tsbuildinfo

# npm pack tarballs (generated by `npm pack` / packaging checks)
*.tgz

# Generated files (root build artifacts from `build:site`; anchored to root so
# they don't also ignore same-named pages under mockups/)
/index.html
/editor.html
/differences.html

# IDE
.idea/
.vscode/*
!.vscode/mcp.json
*.swp
*.swo
.DS_Store

# Logs
*.log
npm-debug.log*

# Wrangler local dev/cache state
website/.wrangler/

# Environment
.env
.env.local
.env.*.local

# Test coverage
coverage/

# Private eval prompts / answer keys
# Public manifests may reference these paths as hidden holdout/holdback stubs.
evals/private/

# Browser test screenshots (generated by agent-browser)
e2e/screenshots/current-*.png

# Stryker mutation testing
.stryker-tmp/
.stryker-tmp-*/
reports/
dist/am

# Claude Code agent worktrees + personal settings (session-transient, never ship).
# Exception: the shared SessionStart hook (.claude/settings.json) IS committed so
# fresh web/CI sessions run `bun install` before the suite (testing-tools #1).
.claude/*
!.claude/settings.json

# Vendored agent skills (installed locally via `npx skills add`, never shipped —
# the repo's distribution policy ships skills under skills/ instead)
.agents/
skills-lock.json

# Ephemeral agent-usage run dirs. Only curated runs (claude-subagent-*/pi-subagent-*)
# are committed as replay fixtures; ad-hoc third-party (no-repo, hosted-MCP) and
# local in-checkout (haiku-local-*/claude-local-*) runs are transient scratch —
# grading is read off, the dir is not shipped.
eval/agent-usage/transcripts/norepo-*/
eval/agent-usage/transcripts/haiku-local-*/
eval/agent-usage/transcripts/claude-local-*/
eval/agent-usage/transcripts/opus-local-*/
eval/agent-usage/transcripts/sonnet-local-*/
eval/agent-usage/transcripts/opusfull-local-*/
