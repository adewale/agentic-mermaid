            "type": "string"
          },
          {
            "name": "to",
            "required": true,
            "type": "string"
          }
        ],
        "set_label": [
          {
            "name": "target",
            "required": true,
            "type": "string"
          },
          {
            "name": "label",
            "required": true,
            "type": "string"
          }
        ],
        "add_edge": [
          {
            "name": "from",
            "required": true,
            "type": "string"
          },
          {
            "name": "to",
            "required": true,
            "type": "string"
          },
          {
            "name": "label",
            "required": false,
            "type": "string"
          },
          {
            "name": "style",
            "required": false,
            "type": "one of \"solid\", \"dotted\", \"thick\", \"invisible\"",
            "note": "default: solid"
          }
        ],
        "remove_edge": [
          {
            "name": "id",
            "required": true,
            "type": "string"
          }
        ]
