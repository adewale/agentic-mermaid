{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agentic Mermaid examples catalog",
  "type": "object",
  "required": [
    "generatedFrom",
    "examples"
  ],
  "properties": {
    "generatedFrom": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "Generated from",
      "type": "object",
      "required": [
        "packageVersion",
        "gitSha",
        "buildTime"
      ],
      "properties": {
        "packageVersion": {
          "type": "string"
        },
        "gitSha": {
          "type": "string"
        },
        "buildTime": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "examples": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "Example entry",
        "type": "object",
        "required": [
          "id",
          "family",
          "label",
          "description",
          "headers",
          "source",
          "galleryUrl",
          "editorUrl",
          "outputs",
          "docs"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "family": {
            "enum": [
              "flowchart",
              "state",
              "sequence",
              "timeline",
              "class",
              "er",
              "journey",
              "architecture",
              "xychart",
              "pie",
              "quadrant",
              "gantt"
            ]
          },
          "label": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "headers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source": {
            "type": "string"
          },
          "galleryUrl": {
            "type": "string"
          },
          "editorUrl": {
            "type": "string"
          },
          "outputs": {
            "type": "array",
            "items": {
              "enum": [
                "svg",
                "ascii",
                "unicode",
                "png",
                "json"
              ]
            }
          },
          "docs": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
