{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agentic Mermaid harnesses",
  "type": "object",
  "required": [
    "default",
    "recommended",
    "server",
    "clients",
    "localMcpTools",
    "localWorkflow",
    "hostedMcp",
    "machineRoutes",
    "generatedFrom"
  ],
  "properties": {
    "default": {
      "const": "stdio"
    },
    "recommended": {
      "const": "self-hosted"
    },
    "server": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "Server command",
      "type": "object",
      "required": [
        "command",
        "args",
        "transport"
      ],
      "properties": {
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transport": {
          "const": "stdio"
        }
      },
      "additionalProperties": false
    },
    "clients": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "MCP client",
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "register": {
            "type": "string"
          },
          "config": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "localMcpTools": {
      "type": "array",
      "items": {
        "enum": [
          "execute",
          "render_png",
          "describe"
        ]
      }
    },
    "localWorkflow": {
      "type": "string"
    },
    "hostedMcp": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "Hosted MCP posture",
      "type": "object",
      "required": [
        "available",
        "url",
        "transport",
        "auth",
        "recommended",
        "execute",
        "tools",
        "localToolSurface",
        "futureHostedConstraint",
        "status"
      ],
      "properties": {
        "available": {
          "const": false
        },
        "url": {
          "type": "null"
        },
        "transport": {
          "const": "streamable-http"
        },
        "auth": {
          "const": "none"
        },
        "recommended": {
          "const": "self-host"
        },
        "execute": {
          "const": false
        },
        "tools": {
          "type": "array",
          "maxItems": 0
        },
        "localToolSurface": {
          "type": "array",
          "items": {
            "enum": [
              "execute",
              "render_png",
              "describe"
            ]
          }
        },
        "futureHostedConstraint": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "machineRoutes": {
      "type": "object"
    },
    "generatedFrom": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "Generated from",
      "type": "object",
      "required": [
        "packageVersion",
        "gitSha",
        "buildTime"
      ],
      "properties": {
        "packageVersion": {
          "type": "string"
        },
        "gitSha": {
          "type": "string"
        },
        "buildTime": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
