{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "_comment": "Narrow mutation lane for quadrant parsing, layout, rendering, and structured mutation.",
  "mutate": ["src/agent/quadrant-body.ts", "src/quadrant/parser.ts", "src/quadrant/layout.ts"],
  "ignorePatterns": ["/site/**", "/dist/**", "/coverage/**", "/.stryker-tmp-*/**"],
  "testRunner": "command",
  "commandRunner": {
    "command": "bun test src/__tests__/agent-quadrant.test.ts src/__tests__/quadrant.test.ts src/__tests__/agent-mermaid-corpus.test.ts"
  },
  "reporters": ["clear-text", "progress", "json"],
  "jsonReporter": { "fileName": "reports/mutation/quadrant-mutation.json" },
  "timeoutMS": 30000,
  "concurrency": 2,
  "tempDirName": ".stryker-tmp-quadrant",
  "disableTypeChecks": true,
  "thresholds": { "break": 44.79 }
}
